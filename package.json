{
  "name": "newgen-navigator",
  "productName": "Newgen Navigator",
  "version": "0.1.0",
  "description": "A modern web browser dressed in classic Netscape-era chrome. Built on Chromium via Electron.",
  "main": "main.js",
  "author": {
    "name": "Newgen Navigator contributors",
    "email": "bp3746@icloud.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/wbp318/newgen_web_browser#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/wbp318/newgen_web_browser.git"
  },
  "bugs": {
    "url": "https://github.com/wbp318/newgen_web_browser/issues"
  },
  "keywords": [
    "browser",
    "electron",
    "chromium",
    "retro",
    "win95",
    "navigator",
    "open-source"
  ],
  "scripts": {
    "start": "electron .",
    "build:icons": "node tools/build-icons.js",
    "predist": "node tools/build-icons.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-builder": "^26.0.0",
    "png2icons": "^2.0.1",
    "sharp": "^0.34.0"
  },
  "overrides": {
    "@electron/asar": "^4.2.0",
    "@electron/get": "^5.0.0",
    "global-agent": "^4.1.3",
    "rimraf@<6": "^6.1.3",
    "glob@<11": "^13.0.6"
  },
  "build": {
    "appId": "org.newgennavigator.app",
    "productName": "Newgen Navigator",
    "copyright": "Copyright (c) 2026 Newgen Navigator contributors",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "home.html",
      "styles.css",
      "assets/**/*",
      "package.json",
      "!**/*.md",
      "!LICENSE",
      "!NOTICE",
      "!.gitattributes",
      "!.gitignore",
      "!.github/**",
      "!.claude/**",
      "!tools/**",
      "!dist/**"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Newgen Navigator",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    },
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Network",
      "synopsis": "Modern browser with classic Netscape-era chrome",
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ]
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    }
  }
}
